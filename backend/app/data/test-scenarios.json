{
  "version": "1.0",
  "description": "AutoMate integration test scenarios for agent intent, tool, and safety validation.",
  "scenarios": [
    {
      "id": "climate-cold",
      "name": "Cold cabin comfort",
      "description": "User feels cold; agent controls climate.",
      "user_input": "나 좀 추워",
      "vehicle_state_overrides": { "is_driving": true, "speed": 72 },
      "expected_intent": "CONTROL_CLIMATE",
      "expected_tool": "setClimate",
      "expected_result": { "success": true },
      "tags": ["climate", "success"]
    },
    {
      "id": "climate-hot",
      "name": "Hot cabin cooling",
      "description": "User feels hot; agent cools cabin.",
      "user_input": "너무 더워",
      "vehicle_state_overrides": { "is_driving": true, "speed": 60 },
      "expected_intent": "CONTROL_CLIMATE",
      "expected_tool": "setClimate",
      "expected_result": { "success": true },
      "tags": ["climate", "success"]
    },
    {
      "id": "nav-home",
